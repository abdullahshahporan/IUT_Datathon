# Copy this file to .env and fill in your values
# cp bot/.env.example bot/.env

# ── Required ──────────────────────────────────────────────────
# Discord bot token — get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ── Optional but strongly recommended ─────────────────────────
# Google Gemini API key for conversational LLM responses
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Discord channel ID where the bot posts proactive alerts
# Right-click any text channel → Copy Channel ID (enable Developer Mode first)
ALERT_CHANNEL_ID=

# ── Service URLs (defaults work with npm run dev) ─────────────
BACKEND_API_URL=http://localhost:4000
BACKEND_SOCKET_URL=http://localhost:4000

# ── Bot behaviour ─────────────────────────────────────────────
COMMAND_PREFIX=!
DISCORD_GUILD_ID=
