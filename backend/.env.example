# Copy this file to .env and fill in your values
# cp backend/.env.example backend/.env

# HTTP port for the backend server
PORT=4000

# Allowed CORS origin — must match where the frontend is served
CORS_ORIGIN=http://localhost:5173

# Device simulator timing (milliseconds)
SIMULATOR_MIN_INTERVAL_MS=3000
SIMULATOR_MAX_INTERVAL_MS=6000
SIMULATOR_INITIAL_DELAY_MS=1000

# Node environment
NODE_ENV=development
